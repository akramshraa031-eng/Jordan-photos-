<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>دليل السياحة الأردني</title>
<style>
body {margin:0;font-family:Arial,sans-serif; background:#f2f2f2; direction:rtl;}
header {background:#ff6b00;color:white;padding:15px;text-align:center;font-size:22px;}
.top-bar {padding:10px;text-align:center;background:white;}
input, select {padding:8px;margin:5px;border-radius:8px;border:1px solid #ccc;}
button {background:#ff6b00;color:white;border:none;padding:8px 12px;border-radius:6px;cursor:pointer;margin-top:5px;}
button:hover {background:#e55d00;}
.container {padding:15px;}
.card {background:white;margin-bottom:20px;border-radius:10px;overflow:hidden;box-shadow:0 3px 10px rgba(0,0,0,0.1);}
.card img {width:100%;height:220px;object-fit:cover;}
.content {padding:10px;}
.stars {color:gold;margin-top:5px;cursor:pointer;}
</style>
</head>
<body>

<header>🇯🇴 دليل السياحة الأردني</header>

<div class="top-bar">
<input type="text" id="username" placeholder="اسم المستخدم">
<input type="password" placeholder="كلمة المرور">
<button onclick="login()">تسجيل دخول</button>
<br>
<input type="text" id="searchInput" placeholder="ابحث عن منطقة">
<button onclick="googleSearch()">بحث Google</button>
<br>
<select id="priceFilter" onchange="filterPrices()">
<option value="all">فلتر حسب السعر</option>
<option value="50">أقل من 50 دينار</option>
<option value="100">أقل من 100 دينار</option>
<option value="200">أقل من 200 دينار</option>
</select>
</div>

<div class="container" id="placesContainer"></div>

<script>
const places = [
{name:"البتراء",price:120,img:"images/petra.jpg"},
{name:"البحر الميت",price:150,img:"images/deadsea.jpg"},
{name:"وادي رم",price:130,img:"images/wadirum.jpg"},
{name:"جرش",price:45,img:"images/jerash.jpg"},
{name:"العقبة",price:140,img:"images/aqaba.jpg"},
{name:"عجلون",price:60,img:"images/ajloun.jpg"},
{name:"مادبا",price:50,img:"images/madaba.jpg"},
{name:"السلط",price:40,img:"images/salt.jpg"},
{name:"الكرك",price:55,img:"images/karak.jpg"},
{name:"ام قيس",price:35,img:"images/umqais.jpg"},
{name:"محمية ضانا",price:90,img:"images/dana.jpg"},
{name:"محمية الأزرق",price:30,img:"images/azraq.jpg"},
{name:"جبل نيبو",price:25,img:"images/mount_nebo.jpg"},
{name:"متحف الأردن",price:20,img:"images/jordan_museum.jpg"},
{name:"قصر عمرة",price:30,img:"images/qasr_amra.jpg"},
{name:"قلعة عجلون",price:35,img:"images/ajloun_castle.jpg"},
{name:"شاطئ العقبة",price:80,img:"images/aqaba_beach.jpg"},
{name:"رأس النقب",price:60,img:"images/ras_naqab.jpg"},
{name:"محمية الشومري",price:45,img:"images/shumari.jpg"},
{name:"وادي الموجب",price:70,img:"images/wadi_mujib.jpg"}
];

function renderPlaces(filter="all"){
    const container = document.getElementById("placesContainer");
    container.innerHTML="";
    places.forEach(place=>{
        if(filter==="all" || place.price <= filter){
            container.innerHTML+=`
            <div class="card">
                <img src="${place.img}" alt="${place.name}">
                <div class="content">
                    <h3>${place.name}</h3>
                    <p>السعر: ${place.price} دينار</p>
                    <button onclick="openMap('${place.name}')">📍 خرائط</button>
                    <div class="stars" onclick="rateStars(this)">⭐ تقييم</div>
                </div>
            </div>`;
        }
    });
}

function openMap(place){
    window.open("https://www.google.com/maps/search/" + encodeURIComponent(place));
}

function googleSearch(){
    const text=document.getElementById("searchInput").value;
    if(text) window.open("https://www.google.com/search?q="+encodeURIComponent(text));
}

function filterPrices(){
    const value=document.getElementById("priceFilter").value;
    renderPlaces(value);
}

function login(){
    const user=document.getElementById("username").value;
    if(user==="") alert("اكتب اسم المستخدم");
    else alert("مرحباً "+user+" 🔥");
}

function rateStars(el){
    el.innerHTML="★★★★★";
}

renderPlaces();
</script>

</body>
</html>
